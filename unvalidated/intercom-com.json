{
  "expires": "2027-04-15",
  "service": {
    "name": "Intercom",
    "domain": "intercom.com",
    "description": "Customer messaging and support platform"
  },
  "policy_id": "intercom_com.terms.2026",
  "extensions": {
    "com.openterms.meta": {
      "method": "complex",
